# .env.example — copy to .env and fill in real values
# NEVER commit .env to git

# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Bootstrap secret for /admin/token — generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=change-me

# Redis connection string (include password if auth is enabled)
REDIS_URL=redis://localhost:6379/1

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

LOG_PATH=/var/log/ritapi_advanced.jsonl

YARA_RULES_DIR=/opt/ritapi_advanced/yara_rules

# Optional: set to protect the /dashboard routes with a bearer token
# Leave empty to allow open access (e.g. in network-restricted environments)
DASHBOARD_TOKEN=
