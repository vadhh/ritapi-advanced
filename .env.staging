# .env.staging — Staging environment configuration for RitAPI Advanced
#
# DO NOT commit real secrets. Inject SECRET_KEY, REDIS_PASSWORD, and
# ADMIN_SECRET via CI secrets, Vault, or docker secret mounts.
#
# Copy this file to .env.staging.local and fill in real values for local
# staging runs. .env.staging.local is gitignored.
#
# Reference: CLAUDE.md — Environment Variables table

# ---------------------------------------------------------------------------
# Auth / JWT
# ---------------------------------------------------------------------------
# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_KEY

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# Admin bootstrap
# ---------------------------------------------------------------------------
# REQUIRED — set a strong random value; used to obtain first SUPER_ADMIN token
# via POST /admin/token with X-Admin-Secret header
ADMIN_SECRET=REPLACE_WITH_GENERATED_SECRET

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# REDIS_URL is overridden in docker/app.yml to point at the internal container.
# Keep this as a fallback for non-Docker staging runs.
REDIS_URL=redis://localhost:6379/1
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD

# Sentinel HA (leave blank to use standalone Redis)
REDIS_SENTINEL_HOSTS=
REDIS_SENTINEL_MASTER=mymaster

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ---------------------------------------------------------------------------
# Routing & policies
# ---------------------------------------------------------------------------
ROUTING_CONFIG_PATH=/app/configs/routing.yml
POLICIES_DIR=/app/configs/policies

# ---------------------------------------------------------------------------
# Bot detection bypass (comma-separated IPs exempt from bot detection)
# Add your monitoring/health-check IPs here
# ---------------------------------------------------------------------------
BOT_DETECTION_BYPASS_IPS=127.0.0.1,::1

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# In Docker this is a volume mount (see docker/app.yml)
LOG_PATH=/var/log/ritapi/ritapi_advanced.jsonl

# ---------------------------------------------------------------------------
# YARA
# ---------------------------------------------------------------------------
YARA_RULES_DIR=/app/rules

# ---------------------------------------------------------------------------
# Environment tag (informational — used in structured logs)
# ---------------------------------------------------------------------------
ENV=staging
